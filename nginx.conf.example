# =====================================================================
# Nginx server block for nexisgd.com — drop into /etc/nginx/sites-available/
# =====================================================================
server {
    listen 80;
    listen [::]:80;
    server_name nexisgd.com www.nexisgd.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name nexisgd.com www.nexisgd.com;

    root /var/www/nexisgd/site;
    index index.html;

    # ---- SSL (replace with your cert paths) ----
    ssl_certificate     /etc/letsencrypt/live/nexisgd.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/nexisgd.com/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;
    ssl_session_cache   shared:SSL:10m;

    # ---- Hide version ----
    server_tokens off;
    more_clear_headers Server;
    more_clear_headers X-Powered-By;

    # ---- Hardened security headers ----
    add_header X-Content-Type-Options   "nosniff"                                  always;
    add_header X-Frame-Options          "DENY"                                     always;
    add_header X-XSS-Protection         "1; mode=block"                            always;
    add_header Strict-Transport-Security "max-age=63072000; includeSubDomains; preload" always;
    add_header Referrer-Policy          "strict-origin-when-cross-origin"          always;
    add_header Permissions-Policy       "geolocation=(), microphone=(), camera=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=(), interest-cohort=()" always;
    add_header Cross-Origin-Opener-Policy   "same-origin-allow-popups" always;
    add_header Cross-Origin-Resource-Policy "same-site"                always;
    add_header Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.tailwindcss.com https://unpkg.com https://www.gstatic.com https://esm.sh https://challenges.cloudflare.com https://pagead2.googlesyndication.com https://fundingchoicesmessages.google.com https://*.google.com https://*.googleadservices.com https://*.googlesyndication.com https://*.doubleclick.net https://www.googletagmanager.com https://www.googletagservices.com https://static.cloudflareinsights.com https://*.adtrafficquality.google; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.tailwindcss.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https:; connect-src 'self' https: wss:; media-src 'self' https: data: blob:; frame-src https://challenges.cloudflare.com https://*.google.com https://*.doubleclick.net https://*.googlesyndication.com https://*.firebaseapp.com; object-src 'none'; base-uri 'none'; form-action 'self'; frame-ancestors 'none'; upgrade-insecure-requests" always;

    # ---- Compression ----
    gzip on;
    gzip_comp_level 6;
    gzip_min_length 1024;
    gzip_types text/plain text/css text/javascript application/javascript application/json image/svg+xml application/xml;

    # ---- Block hidden / source files ----
    location ~ /\.(?!well-known) { deny all; }
    location ~* \.(env|git|gitignore|ini|log|sh|sql|bak|swp|old|orig|map)$ { deny all; }

    # ---- Disable directory listing ----
    autoindex off;

    # ---- Long cache for static assets ----
    location ~* ^/(js|css|assets)/ {
        expires 1y;
        add_header Cache-Control "public, immutable";
    }

    # ---- index.html: no cache ----
    location = /index.html {
        add_header Cache-Control "no-cache, no-store, must-revalidate";
    }

    # ---- SPA fallback ----
    location / {
        try_files $uri $uri/ /index.html;
    }

    # ---- Rate-limit (basic DoS protection) ----
    limit_req_zone $binary_remote_addr zone=nexis:10m rate=20r/s;
    limit_req zone=nexis burst=40 nodelay;
}
